<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Eid Baibalaa 1447 🎉</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: 'Segoe UI', sans-serif;
      color: #fff;
      padding: 20px;
    }

    h1 {
      font-size: 2rem;
      text-align: center;
      margin-bottom: 6px;
      color: #f0c040;
      text-shadow: 0 0 20px rgba(240,192,64,0.5);
      letter-spacing: 2px;
    }

    .subtitle {
      font-size: 0.9rem;
      color: #aaa;
      margin-bottom: 16px;
      text-align: center;
    }

    /* Series bar */
    .series-bar {
      display: flex;
      align-items: center;
      gap: 20px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 40px;
      padding: 8px 24px;
      margin-bottom: 24px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .series-game-label {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #f0c040;
      font-weight: 700;
    }

    .series-wins {
      display: flex;
      gap: 16px;
      font-size: 0.82rem;
      color: #ccc;
    }

    .win-pip {
      display: inline-block;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: rgba(255,255,255,0.2);
      margin-left: 4px;
      vertical-align: middle;
    }

    .win-pip.filled { background: #f0c040; }

    /* Scoreboard */
    .scoreboard {
      display: flex;
      gap: 20px;
      margin-bottom: 20px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .team-card {
      background: rgba(255,255,255,0.07);
      border: 2px solid rgba(255,255,255,0.15);
      border-radius: 20px;
      padding: 28px 36px;
      text-align: center;
      min-width: 190px;
      backdrop-filter: blur(10px);
      transition: border-color 0.3s;
    }

    .team-card.outside { border-color: #e74c3c55; }
    .team-card.inside  { border-color: #2ecc7155; }

    .team-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 3px;
      margin-bottom: 6px;
    }

    .team-card.outside .team-label { color: #e74c3c; }
    .team-card.inside  .team-label { color: #2ecc71; }

    .team-name {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 16px;
      color: #fff;
      cursor: pointer;
      border-bottom: 1px dashed rgba(255,255,255,0.2);
      padding-bottom: 2px;
      transition: border-color 0.2s;
    }

    .team-name:hover { border-color: rgba(255,255,255,0.6); }

    .team-name-input {
      font-size: 1rem;
      font-weight: 700;
      background: rgba(255,255,255,0.1);
      border: 2px solid #f0c040;
      border-radius: 8px;
      color: #fff;
      text-align: center;
      padding: 4px 10px;
      margin-bottom: 16px;
      width: 100%;
      outline: none;
    }

    .score {
      font-size: 5rem;
      font-weight: 900;
      line-height: 1;
      transition: transform 0.15s ease;
      cursor: pointer;
    }

    .score:hover::after {
      content: ' ✎';
      font-size: 1.2rem;
      opacity: 0.4;
      vertical-align: super;
    }

    .team-card.outside .score { color: #e74c3c; }
    .team-card.inside  .score { color: #2ecc71; }

    .score.pop { transform: scale(1.25); }

    .score-input {
      font-size: 4rem;
      font-weight: 900;
      width: 120px;
      text-align: center;
      background: rgba(255,255,255,0.08);
      border: 2px solid #f0c040;
      border-radius: 12px;
      outline: none;
      padding: 4px 8px;
      -moz-appearance: textfield;
      appearance: textfield;
    }

    .score-input::-webkit-inner-spin-button,
    .score-input::-webkit-outer-spin-button { -webkit-appearance: none; }

    .team-card.outside .score-input { color: #e74c3c; }
    .team-card.inside  .score-input { color: #2ecc71; }

    .timer-input {
      font-size: 2.8rem;
      font-weight: 900;
      letter-spacing: 3px;
      width: 160px;
      text-align: center;
      background: rgba(255,255,255,0.08);
      border: 2px solid #f0c040;
      border-radius: 12px;
      color: #fff;
      outline: none;
      padding: 4px 10px;
      font-family: inherit;
    }

    .score-limit {
      font-size: 0.72rem;
      color: #888;
      margin-top: 8px;
    }

    .progress-wrap {
      margin-top: 10px;
      background: rgba(255,255,255,0.1);
      border-radius: 10px;
      height: 7px;
      overflow: hidden;
      width: 100%;
    }

    .progress-bar {
      height: 100%;
      border-radius: 10px;
      background: linear-gradient(90deg, #2ecc71, #a8ff78);
      transition: width 0.4s ease;
    }

    /* Timer */
    .timer-section {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 14px 28px;
    }

    .timer-display {
      font-size: 2.8rem;
      font-weight: 900;
      letter-spacing: 3px;
      color: #fff;
      font-variant-numeric: tabular-nums;
      transition: color 0.4s;
      min-width: 160px;
      text-align: center;
    }

    .timer-display.danger { color: #e74c3c; text-shadow: 0 0 16px rgba(231,76,60,0.6); }

    .timer-divider {
      width: 1px;
      height: 40px;
      background: rgba(255,255,255,0.15);
    }

    .btn-timer-start { background: #2ecc71; color: #fff; }
    .btn-timer-stop  { background: #e74c3c; color: #fff; }
    .btn-timer-reset { background: rgba(255,255,255,0.12); color: #ccc; font-size: 0.85rem; padding: 10px 16px; }

    /* Swap button */
    .swap-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-swap {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.18);
      color: #f0c040;
      font-size: 1.4rem;
      padding: 10px 14px;
      border-radius: 50%;
      line-height: 1;
      transition: background 0.2s, transform 0.2s;
    }

    .btn-swap:hover:not(:disabled) {
      background: rgba(240,192,64,0.15);
      transform: rotate(180deg) scale(1.1);
    }

    .btn-swap:disabled { opacity: 0.25; }

    /* Status */
    .status {
      font-size: 0.9rem;
      color: #ccc;
      min-height: 22px;
      text-align: center;
      margin-bottom: 16px;
      transition: color 0.3s;
    }

    .status.warning { color: #f39c12; font-weight: 700; }

    /* Controls */
    .controls {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 20px;
    }

    .btn-group {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .btn-group-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #888;
    }

    .btn-row { display: flex; gap: 8px; }

    button {
      border: none;
      border-radius: 12px;
      padding: 12px 20px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.1s, opacity 0.2s;
    }

    button:active { transform: scale(0.94); }
    button:disabled { opacity: 0.35; cursor: not-allowed; }

    .btn-plus  { background: #2ecc71; color: #fff; }
    .btn-minus { background: #e74c3c; color: #fff; }
    .btn-reset { background: #f0c040; color: #1a1a2e; margin-top: 10px; }

    /* Overlay */
    .overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.78);
      align-items: center;
      justify-content: center;
      flex-direction: column;
      z-index: 100;
      backdrop-filter: blur(4px);
    }

    .overlay.show { display: flex; }

    .winner-box {
      background: linear-gradient(135deg, #1a1a2e, #0f3460);
      border: 3px solid #f0c040;
      border-radius: 24px;
      padding: 44px 56px;
      text-align: center;
      max-width: 420px;
      width: 90%;
      animation: popIn 0.4s ease;
    }

    @keyframes popIn {
      from { transform: scale(0.6); opacity: 0; }
      to   { transform: scale(1);   opacity: 1; }
    }

    .winner-emoji  { font-size: 3.6rem; margin-bottom: 8px; }
    .winner-context{ font-size: 0.75rem; color: #888; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 4px; }
    .winner-title  { font-size: 0.95rem; color: #aaa; letter-spacing: 3px; text-transform: uppercase; }
    .winner-name   { font-size: 2.2rem; font-weight: 900; color: #f0c040; margin: 8px 0 4px; }
    .winner-score  { font-size: 0.92rem; color: #ccc; margin-bottom: 8px; }

    .fixture-result {
      margin: 12px 0 20px;
      padding: 12px 16px;
      background: rgba(255,255,255,0.06);
      border-radius: 12px;
      font-size: 0.88rem;
      color: #eee;
      line-height: 1.7;
    }

    .fixture-result strong { color: #f0c040; }

    .overlay-btn-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .btn-next {
      background: #f0c040;
      color: #1a1a2e;
      font-size: 1rem;
      padding: 13px 30px;
      border-radius: 14px;
      font-weight: 900;
    }

    .btn-new-match {
      background: rgba(255,255,255,0.1);
      color: #ccc;
      font-size: 0.9rem;
      padding: 13px 20px;
      border-radius: 14px;
    }

    /* Rules */
    .rules-toggle {
      font-size: 0.78rem;
      color: #888;
      cursor: pointer;
      text-decoration: underline;
      margin-top: 10px;
    }

    .rules-box {
      display: none;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 14px 18px;
      max-width: 360px;
      margin-top: 10px;
      font-size: 0.8rem;
      color: #bbb;
      line-height: 1.7;
    }

    .rules-box.show { display: block; }
    .rules-box li { margin-left: 16px; margin-bottom: 3px; }

    /* ── Game Day Panel ── */
    .game-day-panel {
      width: 100%;
      max-width: 560px;
      margin-bottom: 16px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.1);
      overflow: hidden;
    }

    .game-day-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 20px;
      background: rgba(255,255,255,0.07);
      cursor: pointer;
      user-select: none;
      gap: 10px;
    }

    .game-day-header:hover { background: rgba(255,255,255,0.1); }

    .gd-header-left {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.82rem;
      font-weight: 700;
      color: #f0c040;
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    .gd-fixture-count { color: #777; font-weight: 400; letter-spacing: 0; text-transform: none; font-size: 0.78rem; }

    .gd-chevron { color: #666; font-size: 0.8rem; transition: transform 0.2s; }
    .game-day-panel.open .gd-chevron { transform: rotate(180deg); }

    .game-day-body {
      display: none;
      padding: 14px 18px 16px;
      background: rgba(0,0,0,0.25);
    }

    .game-day-panel.open .game-day-body { display: block; }

    .gd-name-row {
      margin-bottom: 12px;
    }

    .gd-name-input {
      width: 100%;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      color: #f0c040;
      font-size: 0.92rem;
      font-weight: 700;
      padding: 7px 12px;
      outline: none;
      letter-spacing: 1px;
    }

    .gd-name-input:focus { border-color: rgba(240,192,64,0.5); }

    .fixture-list {
      display: flex;
      flex-direction: column;
      gap: 7px;
      margin-bottom: 14px;
      max-height: 280px;
      overflow-y: auto;
    }

    .fixture-row {
      display: flex;
      align-items: center;
      gap: 9px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 9px 13px;
      transition: border-color 0.2s;
    }

    .fixture-row.fx-active { border-color: rgba(240,192,64,0.4); background: rgba(240,192,64,0.05); }
    .fixture-row.fx-done   { opacity: 0.55; }

    .fx-num { font-size: 0.72rem; color: #555; min-width: 16px; }

    .fx-badge {
      width: 18px; height: 18px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.62rem; font-weight: 900;
      flex-shrink: 0;
    }

    .fx-badge.fx-pending { background: rgba(255,255,255,0.1);  color: #888; }
    .fx-badge.fx-active  { background: #f0c040; color: #1a1a2e; animation: blink 1.2s infinite; }
    .fx-badge.fx-done    { background: #2ecc71; color: #fff; }

    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.35} }

    .fx-teams { flex: 1; font-size: 0.86rem; color: #ddd; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .fx-teams .vs { color: #555; font-size: 0.72rem; margin: 0 5px; }

    .fx-result { font-size: 0.74rem; color: #2ecc71; min-width: 90px; text-align: right; white-space: nowrap; }
    .fx-result.draw { color: #aaa; }

    .fx-load-btn {
      background: rgba(240,192,64,0.12);
      border: 1px solid rgba(240,192,64,0.28);
      color: #f0c040;
      font-size: 0.76rem;
      padding: 5px 11px;
      border-radius: 8px;
      font-weight: 700;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .fx-load-btn:hover { background: rgba(240,192,64,0.22); }

    .fx-empty { font-size: 0.8rem; color: #555; text-align: center; padding: 14px 0; }

    .add-fixture-form {
      display: flex;
      gap: 7px;
      flex-wrap: wrap;
      align-items: center;
      padding-top: 12px;
      border-top: 1px solid rgba(255,255,255,0.07);
    }

    .fx-input {
      flex: 1;
      min-width: 110px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      color: #fff;
      font-size: 0.84rem;
      padding: 7px 11px;
      outline: none;
    }

    .fx-input::placeholder { color: #555; }
    .fx-input:focus { border-color: rgba(240,192,64,0.4); }

    .btn-add-fixture {
      background: #f0c040;
      color: #1a1a2e;
      font-size: 0.84rem;
      padding: 7px 16px;
      border-radius: 8px;
      font-weight: 900;
      white-space: nowrap;
    }

    .preset-row {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .preset-label {
      font-size: 0.72rem;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 1px;
      white-space: nowrap;
    }

    .btn-preset {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      color: #ccc;
      font-size: 0.78rem;
      padding: 5px 12px;
      border-radius: 8px;
      font-weight: 600;
      white-space: nowrap;
      transition: background 0.2s, border-color 0.2s;
    }

    .btn-preset:hover { background: rgba(255,255,255,0.12); border-color: rgba(240,192,64,0.3); color: #f0c040; }
  </style>
</head>
<body>

  <h1>🌙 Eid Baibalaa 1447 🌙</h1>
  <p class="subtitle">Live Scoreboard</p>

  <!-- Game Day Panel -->
  <div class="game-day-panel" id="game-day-panel">
    <div class="game-day-header" onclick="toggleGameDayPanel()">
      <div class="gd-header-left">
        📋 <span id="gd-header-name">Game Day 1</span>
        <span class="gd-fixture-count" id="gd-fixture-count">· 0 fixtures</span>
      </div>
      <span class="gd-chevron">▼</span>
    </div>
    <div class="game-day-body">
      <div class="gd-name-row">
        <input class="gd-name-input" id="gd-name-input" value="Game Day 1"
               placeholder="Game Day name" maxlength="40"
               oninput="updateGameDayName()" />
      </div>
      <div class="preset-row">
        <span class="preset-label">Quick load:</span>
        <button class="btn-preset" onclick="loadPreset(1)">📅 Day 1 — 21 Mar</button>
        <button class="btn-preset" onclick="loadPreset(2)">📅 Day 2 — 22 Mar</button>
      </div>
      <div class="fixture-list" id="fixture-list">
        <div class="fx-empty">No fixtures yet. Add one below.</div>
      </div>
      <div class="add-fixture-form">
        <input class="fx-input" id="fx-outside-input" placeholder="Outside team" maxlength="20" list="team-suggestions" autocomplete="off" />
        <input class="fx-input" id="fx-inside-input"  placeholder="Inside team"  maxlength="20" list="team-suggestions" autocomplete="off" />
        <datalist id="team-suggestions"></datalist>
        <button class="btn-add-fixture" onclick="addFixture()">+ Add</button>
      </div>
    </div>
  </div>

  <!-- Series tracker -->
  <div class="series-bar">
    <span class="series-game-label" id="series-game-label">Game 1 of 2</span>
    <div class="series-wins" id="series-wins-display">
      <span id="wins-A">— <span class="win-pip"></span><span class="win-pip"></span></span>
      <span style="color:#555">|</span>
      <span id="wins-B">— <span class="win-pip"></span><span class="win-pip"></span></span>
    </div>
  </div>

  <!-- Scoreboard -->
  <div class="scoreboard">

    <div class="team-card outside">
      <div class="team-label">Outside</div>
      <div class="team-name" id="outside-name" onclick="editName('outside')" title="Click to rename">Outside Team</div>
      <div class="score" id="outside-score" onclick="editScore('outside')" title="Click to correct score">0</div>
      <div class="score-limit">↑ scores go up</div>
    </div>

    <div class="swap-wrap">
      <button class="btn-swap" id="swap-btn" onclick="swapNames()" title="Swap team sides">⇄</button>
    </div>

    <div class="team-card inside">
      <div class="team-label">Inside</div>
      <div class="team-name" id="inside-name" onclick="editName('inside')" title="Click to rename">Inside Team</div>
      <div class="score" id="inside-score" onclick="editScore('inside')" title="Click to correct score">10</div>
      <div class="score-limit">Max: 20 pts</div>
      <div class="progress-wrap">
        <div class="progress-bar" id="inside-progress" style="width:50%"></div>
      </div>
    </div>

  </div>

  <!-- Stopclock timer -->
  <div class="timer-section">
    <div class="timer-display" id="timer-display" onclick="editTimer()" title="Click to set time">6:00</div>
    <div class="timer-divider"></div>
    <button id="timer-btn" class="btn-timer-start" onclick="toggleTimer()">▶ Start</button>
    <button id="timer-reset-btn" class="btn-timer-reset" onclick="resetTimer()">↺ Reset</button>
  </div>

  <div class="status" id="status">Game in progress...</div>

  <!-- Score controls -->
  <div class="controls">

    <div class="btn-group">
      <div class="btn-group-label" id="outside-btn-label">Outside Scores</div>
      <div class="btn-row">
        <button class="btn-plus" id="outside-btn" onclick="outsideScores()">+1 Outside</button>
      </div>
    </div>

    <div class="btn-group">
      <div class="btn-group-label" id="inside-btn-label">Inside Scores</div>
      <div class="btn-row">
        <button class="btn-plus" id="inside-btn" onclick="insideScores()">+1 Inside</button>
      </div>
    </div>

    <div class="btn-group">
      <div class="btn-group-label">Undo</div>
      <div class="btn-row">
        <button class="btn-minus" id="undo-btn" onclick="undo()" disabled>↩ Undo</button>
      </div>
    </div>

  </div>

  <button class="btn-reset" onclick="resetAll()">↺ New Match</button>

  <div class="rules-toggle" onclick="toggleRules()">📜 Show Rules</div>
  <div class="rules-box" id="rules-box">
    <ul>
      <li>Inside team starts with <strong>10 points</strong>.</li>
      <li>Outside team starts from <strong>0 points</strong>.</li>
      <li>When <strong>Outside scores</strong>: Outside +1, Inside −1.</li>
      <li>When <strong>Inside scores</strong> (eliminates outside player): Inside +1.</li>
      <li>Inside reaches <strong>20 pts</strong> → Inside wins the game.</li>
      <li>Outside score <strong>overtakes</strong> inside score → Outside wins.</li>
      <li><strong>6-minute timer</strong>: when time is up, higher score wins.</li>
      <li>Each team plays <strong>2 games</strong> (swapping inside/outside).</li>
      <li>Win both games to win the <strong>fixture</strong>.</li>
    </ul>
  </div>

  <!-- Game / fixture result overlay -->
  <div class="overlay" id="overlay">
    <div class="winner-box">
      <div class="winner-emoji"  id="winner-emoji">🏆</div>
      <div class="winner-context" id="winner-context">Game 1 Result</div>
      <div class="winner-title"  id="winner-title">Winner</div>
      <div class="winner-name"   id="winner-name">—</div>
      <div class="winner-score"  id="winner-score"></div>
      <div class="fixture-result" id="fixture-result" style="display:none"></div>
      <div class="overlay-btn-row">
        <button class="btn-next" id="overlay-main-btn" onclick="overlayMainAction()">—</button>
        <button class="btn-new-match" onclick="resetAll()">New Match</button>
      </div>
    </div>
  </div>

  <script>
    // ─── State ────────────────────────────────────────────────────────────────

    const state = {
      outside: 0,
      inside:  10,
      history: [],
      gameOver: false,
      names: { outside: 'Outside Team', inside: 'Inside Team' }
    };

    // series.nameA = team that started inside in Game 1
    // series.nameB = team that started outside in Game 1
    const series = {
      game:    1,
      results: [],   // 'A' | 'B' | 'draw' per game
      nameA:   null,
      nameB:   null,
      done:    false
    };

    const timer = {
      remaining: 36000,  // centiseconds (360s × 100)
      running:   false,
      interval:  null,
      endAt:     null    // Date.now() target, for drift-free countdown
    };

    // ─── Timer ────────────────────────────────────────────────────────────────

    function toggleTimer() {
      if (state.gameOver) return;
      if (timer.running) {
        stopTimer();
      } else {
        startTimer();
      }
    }

    function startTimer() {
      if (timer.remaining <= 0 || state.gameOver) return;
      timer.running = true;
      timer.endAt   = Date.now() + timer.remaining * 10; // cs → ms
      const btn = document.getElementById('timer-btn');
      btn.textContent = '⏸ Stop';
      btn.className   = 'btn-timer-stop';
      timer.interval  = setInterval(() => {
        // drift-free: recompute from wall clock
        timer.remaining = Math.max(0, Math.round((timer.endAt - Date.now()) / 10));
        renderTimer();
        if (timer.remaining <= 0) {
          clearInterval(timer.interval);
          timer.running = false;
          timeUp();
        }
      }, 10);
    }

    function stopTimer() {
      clearInterval(timer.interval);
      timer.running = false;
      const btn = document.getElementById('timer-btn');
      btn.textContent = '▶ Resume';
      btn.className   = 'btn-timer-start';
    }

    function editTimer() {
      if (timer.running) return; // only editable when stopped
      const el = document.getElementById('timer-display');
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'timer-input';
      // format current value as M:SS
      const totalSecs = Math.floor(timer.remaining / 100);
      const mins = Math.floor(totalSecs / 60), secs = totalSecs % 60;
      input.value = `${mins}:${secs.toString().padStart(2,'0')}`;
      input.placeholder = 'M:SS';
      el.replaceWith(input);
      input.focus(); input.select();

      function commit() {
        const match = input.value.trim().match(/^(\d+):([0-5]\d)$/);
        const newEl = document.createElement('div');
        newEl.className = 'timer-display';
        newEl.id = 'timer-display';
        newEl.title = 'Click to set time';
        newEl.onclick = editTimer;
        if (match) {
          const newRemaining = (parseInt(match[1]) * 60 + parseInt(match[2])) * 100;
          timer.remaining = Math.max(0, newRemaining);
        }
        const ts = Math.floor(timer.remaining / 100);
        const cs = timer.remaining % 100;
        const m = Math.floor(ts / 60), s = ts % 60;
        newEl.textContent = `${m}:${s.toString().padStart(2,'0')}.${cs.toString().padStart(2,'0')}`;
        newEl.className = (timer.remaining > 3000) ? 'timer-display' : 'timer-display danger';
        input.replaceWith(newEl);
      }

      input.addEventListener('blur', commit);
      input.addEventListener('keydown', e => {
        if (e.key === 'Enter') input.blur();
        if (e.key === 'Escape') { input.value = `${mins}:${secs.toString().padStart(2,'0')}`; input.blur(); }
      });
    }

    function resetTimer() {
      stopTimer();
      timer.remaining = 36000;
      renderTimer(true);
      const btn = document.getElementById('timer-btn');
      btn.textContent = '▶ Start';
    }

    function renderTimer(forceWhite) {
      const totalSecs = Math.floor(timer.remaining / 100);
      const cs        = timer.remaining % 100;
      const mins      = Math.floor(totalSecs / 60);
      const secs      = totalSecs % 60;
      const el        = document.getElementById('timer-display');
      el.textContent  = `${mins}:${secs.toString().padStart(2,'0')}.${cs.toString().padStart(2,'0')}`;
      // RED for last 30 seconds (≤ 3000 cs), else normal
      if (forceWhite || timer.remaining > 3000) {
        el.className = 'timer-display';
      } else {
        el.className = 'timer-display danger';
      }
    }

    function timeUp() {
      const inn = state.names.inside;
      const out = state.names.outside;
      if (state.inside > state.outside) {
        endGame(inn, '⏱', `Time's up! ${inn} wins — ${state.inside} vs ${state.outside}`);
      } else if (state.outside > state.inside) {
        endGame(out, '⏱', `Time's up! ${out} wins — ${state.outside} vs ${state.inside}`);
      } else {
        endGame(null, '🤝', `Time's up! Draw — ${state.inside} vs ${state.outside}`);
      }
    }

    // ─── Team name editing ────────────────────────────────────────────────────

    function editName(side) {
      if (series.game === 2) return; // lock names in game 2
      const nameEl  = document.getElementById(side + '-name');
      const current = state.names[side];

      const input = document.createElement('input');
      input.type      = 'text';
      input.className = 'team-name-input';
      input.value     = current;
      input.maxLength = 20;
      nameEl.replaceWith(input);
      input.focus();
      input.select();

      function commit() {
        const val = input.value.trim() || current;
        state.names[side] = val;
        const div = document.createElement('div');
        div.className = 'team-name';
        div.id        = side + '-name';
        div.title     = 'Click to rename';
        div.textContent = val;
        div.onclick   = () => editName(side);
        input.replaceWith(div);
        saveTeamName(val);
        updateButtonLabels();
        renderSeriesBar();
      }

      input.addEventListener('blur', commit);
      input.addEventListener('keydown', e => {
        if (e.key === 'Enter')  input.blur();
        if (e.key === 'Escape') { input.value = current; input.blur(); }
      });
    }

    function editScore(side) {
      if (state.gameOver) return;
      const scoreEl  = document.getElementById(side + '-score');
      const current  = side === 'outside' ? state.outside : state.inside;
      const min      = 0;
      const max      = side === 'inside' ? 20 : 999;

      const input = document.createElement('input');
      input.type      = 'number';
      input.className = 'score-input';
      input.value     = current;
      input.min       = min;
      input.max       = max;
      scoreEl.replaceWith(input);
      input.focus();
      input.select();

      function commit() {
        let val = parseInt(input.value, 10);
        if (isNaN(val)) val = current;
        val = Math.max(min, Math.min(max, val));

        if (val !== current) {
          pushHistory();
          if (side === 'outside') state.outside = val;
          else                    state.inside  = val;
        }

        const div = document.createElement('div');
        div.className = 'score';
        div.id        = side + '-score';
        div.title     = 'Click to correct score';
        div.textContent = val;
        div.onclick   = () => editScore(side);
        input.replaceWith(div);
        render();
        checkWin();
      }

      input.addEventListener('blur', commit);
      input.addEventListener('keydown', e => {
        if (e.key === 'Enter')  input.blur();
        if (e.key === 'Escape') { input.value = current; input.blur(); }
      });
    }

    function swapNames() {
      if (series.game === 2 || state.gameOver) return;
      const tmp           = state.names.inside;
      state.names.inside  = state.names.outside;
      state.names.outside = tmp;
      document.getElementById('outside-name').textContent = state.names.outside;
      document.getElementById('inside-name').textContent  = state.names.inside;
      updateButtonLabels();
      renderSeriesBar();
    }

    function updateButtonLabels() {
      document.getElementById('outside-btn-label').textContent = state.names.outside + ' Scores';
      document.getElementById('outside-btn').textContent       = '+1 ' + state.names.outside;
      document.getElementById('inside-btn-label').textContent  = state.names.inside  + ' Scores';
      document.getElementById('inside-btn').textContent        = '+1 ' + state.names.inside;
    }

    // ─── Scoreboard render ────────────────────────────────────────────────────

    function render() {
      document.getElementById('outside-score').textContent = state.outside;
      document.getElementById('inside-score').textContent  = state.inside;

      const pct = Math.max(0, Math.min(100, (state.inside / 20) * 100));
      document.getElementById('inside-progress').style.width = pct + '%';

      const diff     = state.inside - state.outside;
      const statusEl = document.getElementById('status');
      const inn = state.names.inside;
      const out = state.names.outside;

      if (!state.gameOver) {
        if (diff <= 2 && diff > 0) {
          statusEl.textContent = `⚠️ ${out} is closing in! Gap: ${diff}`;
          statusEl.className   = 'status warning';
        } else if (diff <= 0) {
          statusEl.textContent = '';
          statusEl.className   = 'status';
        } else {
          statusEl.textContent = `${inn} leads by ${diff} — ${out} needs ${diff + 1} to win`;
          statusEl.className   = 'status';
        }
      }

      document.getElementById('undo-btn').disabled =
        state.history.length === 0 || state.gameOver;
      document.getElementById('swap-btn').disabled =
        series.game === 2 || state.gameOver;
    }

    function renderSeriesBar() {
      document.getElementById('series-game-label').textContent =
        `Game ${series.game} of 2`;

      const nameA = series.nameA || state.names.inside;
      const nameB = series.nameB || state.names.outside;
      const winsA = series.results.filter(r => r === 'A').length;
      const winsB = series.results.filter(r => r === 'B').length;

      document.getElementById('wins-A').innerHTML =
        `${nameA} ${pip(winsA >= 1)} ${pip(winsA >= 2)}`;
      document.getElementById('wins-B').innerHTML =
        `${nameB} ${pip(winsB >= 1)} ${pip(winsB >= 2)}`;
    }

    function pip(filled) {
      return `<span class="win-pip${filled ? ' filled' : ''}"></span>`;
    }

    // ─── Game logic ───────────────────────────────────────────────────────────

    function pop(elId) {
      const el = document.getElementById(elId);
      el.classList.add('pop');
      setTimeout(() => el.classList.remove('pop'), 200);
    }

    function pushHistory() {
      state.history.push({ outside: state.outside, inside: state.inside });
      if (state.history.length > 30) state.history.shift();
    }

    function checkWin() {
      const inn = state.names.inside;
      const out = state.names.outside;
      if (state.inside >= 20) {
        endGame(inn, '🎉', `${inn} ${state.inside} — ${out} ${state.outside}`);
        return true;
      }
      if (state.outside > state.inside) {
        endGame(out, '🏆', `${out} ${state.outside} — ${inn} ${state.inside}`);
        return true;
      }
      return false;
    }

    function outsideScores() {
      if (state.gameOver) return;
      pushHistory();
      state.outside += 1;
      state.inside  -= 1;
      pop('outside-score');
      render();
      checkWin();
    }

    function insideScores() {
      if (state.gameOver) return;
      if (state.inside >= 20) return;
      pushHistory();
      state.inside += 1;
      pop('inside-score');
      render();
      checkWin();
    }

    function undo() {
      if (state.history.length === 0) return;
      const prev    = state.history.pop();
      state.outside = prev.outside;
      state.inside  = prev.inside;
      render();
    }

    // ─── End game / series ────────────────────────────────────────────────────

    function endGame(winnerName, emoji, scoreText) {
      stopTimer();
      state.gameOver = true;
      document.getElementById('status').textContent = '';

      // Lock-in series names on first end-game call
      if (series.game === 1) {
        if (!series.nameA) {
          series.nameA = state.names.inside;
          series.nameB = state.names.outside;
        }
      }

      // Record result: who is A vs B?
      let result;
      if (winnerName === null) {
        result = 'draw';
      } else if (winnerName === series.nameA) {
        result = 'A';
      } else {
        result = 'B';
      }
      series.results.push(result);

      // Populate overlay
      document.getElementById('winner-emoji').textContent   = emoji;
      document.getElementById('winner-context').textContent = `Game ${series.game} of 2`;
      document.getElementById('winner-score').textContent   = scoreText;

      if (winnerName) {
        document.getElementById('winner-title').textContent = 'Winner';
        document.getElementById('winner-name').textContent  = winnerName;
      } else {
        document.getElementById('winner-title').textContent = '';
        document.getElementById('winner-name').textContent  = 'Draw';
      }

      if (series.game === 1) {
        // Show "Start Game 2" — teams will swap
        document.getElementById('fixture-result').style.display = 'none';
        const mainBtn = document.getElementById('overlay-main-btn');
        mainBtn.textContent = 'Start Game 2 →';
        mainBtn.style.display = '';
      } else {
        // Series complete — determine fixture winner
        series.done = true;
        showFixtureResult();
      }

      document.getElementById('overlay').classList.add('show');
      renderSeriesBar();
    }

    function showFixtureResult() {
      const winsA = series.results.filter(r => r === 'A').length;
      const winsB = series.results.filter(r => r === 'B').length;
      const nameA = series.nameA;
      const nameB = series.nameB;

      let fixtureHtml, fixtureName, fixtureEmoji;

      if (winsA === 2) {
        fixtureName  = nameA;
        fixtureEmoji = '🏆';
        fixtureHtml  = `<strong>${nameA}</strong> wins the fixture 2–0!`;
      } else if (winsB === 2) {
        fixtureName  = nameB;
        fixtureEmoji = '🏆';
        fixtureHtml  = `<strong>${nameB}</strong> wins the fixture 2–0!`;
      } else {
        fixtureName  = 'No one';
        fixtureEmoji = '🤝';
        fixtureHtml  = `Series drawn 1–1 between <strong>${nameA}</strong> and <strong>${nameB}</strong>.`;
      }

      document.getElementById('winner-emoji').textContent  = fixtureEmoji;
      document.getElementById('winner-context').textContent = 'Fixture Result';
      document.getElementById('winner-title').textContent  = winsA === winsB ? '' : 'Fixture Winner';
      document.getElementById('winner-name').textContent   = winsA === winsB ? 'Series Drawn' : fixtureName;

      const fixtureEl = document.getElementById('fixture-result');
      fixtureEl.innerHTML      = fixtureHtml;
      fixtureEl.style.display  = 'block';

      const mainBtn = document.getElementById('overlay-main-btn');
      mainBtn.style.display = 'none'; // only "New Match" is shown

      // Mark active fixture as complete
      markFixtureDone(winsA === 2 ? nameA : (winsB === 2 ? nameB : null));
    }

    function overlayMainAction() {
      // Called only after Game 1 — starts Game 2
      document.getElementById('overlay').classList.remove('show');
      startGame2();
    }

    function startGame2() {
      series.game = 2;

      // Swap sides
      const tmp = state.names.inside;
      state.names.inside  = state.names.outside;
      state.names.outside = tmp;

      // Update DOM name labels
      document.getElementById('outside-name').textContent = state.names.outside;
      document.getElementById('inside-name').textContent  = state.names.inside;

      // Reset scores and game state
      state.outside  = 0;
      state.inside   = 10;
      state.history  = [];
      state.gameOver = false;

      // Reset timer
      resetTimer();

      document.getElementById('status').className   = 'status';
      document.getElementById('status').textContent = 'Game 2 — sides swapped!';
      setTimeout(() => {
        if (!state.gameOver)
          document.getElementById('status').textContent = 'Game in progress...';
      }, 2500);

      updateButtonLabels();
      render();
      renderSeriesBar();
    }

    function resetAll() {
      stopTimer();
      timer.remaining = 36000;

      state.outside  = 0;
      state.inside   = 10;
      state.history  = [];
      state.gameOver = false;
      state.names    = { outside: 'Outside Team', inside: 'Inside Team' };

      series.game    = 1;
      series.results = [];
      series.nameA   = null;
      series.nameB   = null;
      series.done    = false;

      document.getElementById('outside-name').textContent = state.names.outside;
      document.getElementById('inside-name').textContent  = state.names.inside;
      document.getElementById('overlay').classList.remove('show');
      document.getElementById('status').className   = 'status';
      document.getElementById('status').textContent = 'Game in progress...';

      updateButtonLabels();
      render();
      renderTimer(true);
      renderSeriesBar();

      const btn = document.getElementById('timer-btn');
      btn.textContent = '▶ Start';
      btn.className   = 'btn-timer-start';
    }

    function toggleRules() {
      document.getElementById('rules-box').classList.toggle('show');
    }

    // ─── Team name memory (localStorage) ─────────────────────────────────────

    const STORAGE_KEY = 'baibalaa_teams';

    function loadTeamNames() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
      } catch { return []; }
    }

    function saveTeamName(name) {
      if (!name || name.length < 2) return;
      const names = loadTeamNames();
      if (!names.includes(name)) {
        names.unshift(name);           // most-recent first
        if (names.length > 60) names.pop();
        localStorage.setItem(STORAGE_KEY, JSON.stringify(names));
        refreshDatalist();
      }
    }

    function refreshDatalist() {
      const dl = document.getElementById('team-suggestions');
      dl.innerHTML = loadTeamNames()
        .map(n => `<option value="${n.replace(/"/g, '&quot;')}">`)
        .join('');
    }

    // ─── Preset schedules ─────────────────────────────────────────────────────

    const PRESETS = {
      1: {
        name: 'Day 1 — 21 March',
        fixtures: [
          { outside: 'HUDA HENVEIRU UNITED', inside: 'THE ONE SPORTS CLUB' },
          { outside: 'HUDA HENVEIRU LIONS',  inside: 'THE BEEGEES' },
          { outside: 'LORENZO SPORTS CLUB',  inside: 'TC SPORTS CLUB' },
          { outside: 'BURU SPORTS CLUB',     inside: 'CLUB KARSINJEE' },
          { outside: 'KARSINJAAS',           inside: 'TC FRATERNITY' },
          { outside: 'THE WOLVES CLUB',      inside: 'JANAVAREEYAN S' },
          { outside: 'CLUB TEENAGE',         inside: 'CLUB ZEPROL' },
        ]
      },
      2: {
        name: 'Day 2 — 22 March',
        fixtures: [
          { outside: 'ODI SPORTS CLUB',    inside: 'SD2 SHARKS' },
          { outside: 'ODI TITANS',         inside: 'ZEPPO NEW GENERATION' },
          { outside: 'ZEPPO SPORTS CLUB',  inside: 'TC CLASSIQUE' },
          { outside: 'HANHA VAIHANMATHI', inside: 'WEST SPORTS CLUB' },
          { outside: 'JANAVAREE MAGU SC', inside: 'ALPHA WOLVES' },
          { outside: 'LORENZO HYENAS',    inside: 'JEB UNITED' },
          { outside: 'TEENAGE VETERANS',  inside: 'CLUB O1O' },
          { outside: 'UNT SPORTS CLUB',   inside: 'VK SPORTS CLUB' },
          { outside: 'LIONS & TIGERS',    inside: 'TPT' },
        ]
      }
    };

    function loadPreset(day) {
      const preset = PRESETS[day];
      if (!preset) return;

      if (gameDay.fixtures.length > 0) {
        if (!confirm(`Replace current fixtures with ${preset.name}?`)) return;
      }

      // Reset game day
      gameDay.fixtures  = [];
      gameDay.activeId  = null;
      gameDay.nextId    = 1;
      gameDay.name      = preset.name;
      document.getElementById('gd-name-input').value        = preset.name;
      document.getElementById('gd-header-name').textContent = preset.name;

      preset.fixtures.forEach(fx => {
        gameDay.fixtures.push({
          id:      gameDay.nextId++,
          outside: fx.outside,
          inside:  fx.inside,
          status:  'pending',
          winner:  null
        });
        saveTeamName(fx.outside);
        saveTeamName(fx.inside);
      });

      renderFixtureList();
    }

    // ─── Game Day ─────────────────────────────────────────────────────────────

    const gameDay = {
      name:     'Game Day 1',
      fixtures: [],   // { id, outside, inside, status: 'pending'|'active'|'done', winner: null|name }
      activeId: null,
      nextId:   1
    };

    function toggleGameDayPanel() {
      document.getElementById('game-day-panel').classList.toggle('open');
    }

    function updateGameDayName() {
      gameDay.name = document.getElementById('gd-name-input').value || 'Game Day 1';
      document.getElementById('gd-header-name').textContent = gameDay.name;
    }

    function addFixture() {
      const outEl  = document.getElementById('fx-outside-input');
      const inEl   = document.getElementById('fx-inside-input');
      const outside = outEl.value.trim();
      const inside  = inEl.value.trim();
      if (!outside || !inside) return;

      gameDay.fixtures.push({
        id: gameDay.nextId++,
        outside, inside,
        status: 'pending',
        winner: null
      });

      saveTeamName(outside);
      saveTeamName(inside);
      outEl.value = '';
      inEl.value  = '';
      outEl.focus();
      renderFixtureList();
    }

    function loadFixture(id) {
      const fx = gameDay.fixtures.find(f => f.id === id);
      if (!fx || fx.status === 'done') return;

      // Deactivate previously active fixture
      if (gameDay.activeId !== null && gameDay.activeId !== id) {
        const prev = gameDay.fixtures.find(f => f.id === gameDay.activeId);
        if (prev && prev.status === 'active') prev.status = 'pending';
      }

      gameDay.activeId = id;
      fx.status = 'active';

      resetAll();
      state.names.outside = fx.outside;
      state.names.inside  = fx.inside;
      document.getElementById('outside-name').textContent = fx.outside;
      document.getElementById('inside-name').textContent  = fx.inside;
      updateButtonLabels();
      renderFixtureList();

      // Close panel so scoreboard is in view
      document.getElementById('game-day-panel').classList.remove('open');
    }

    function markFixtureDone(winnerName) {
      if (gameDay.activeId === null) return;
      const fx = gameDay.fixtures.find(f => f.id === gameDay.activeId);
      if (!fx) return;
      fx.status = 'done';
      fx.winner = winnerName; // null = draw
      gameDay.activeId = null;
      renderFixtureList();
    }

    function renderFixtureList() {
      const list  = document.getElementById('fixture-list');
      const count = gameDay.fixtures.length;

      document.getElementById('gd-fixture-count').textContent =
        `· ${count} fixture${count !== 1 ? 's' : ''}`;

      if (count === 0) {
        list.innerHTML = '<div class="fx-empty">No fixtures yet. Add one below.</div>';
        return;
      }

      list.innerHTML = gameDay.fixtures.map((fx, i) => {
        const badge  = fx.status === 'done' ? '✓' : (fx.status === 'active' ? '●' : '·');
        const result = fx.status === 'done'
          ? `<span class="fx-result${fx.winner ? '' : ' draw'}">${fx.winner ? '🏆 ' + fx.winner : '🤝 Draw'}</span>`
          : '';
        const loadBtn = fx.status !== 'done'
          ? `<button class="fx-load-btn" onclick="loadFixture(${fx.id})">Load →</button>`
          : '';
        return `
        <div class="fixture-row fx-${fx.status}">
          <span class="fx-num">${i + 1}.</span>
          <span class="fx-badge fx-${fx.status}">${badge}</span>
          <span class="fx-teams">${fx.outside} <span class="vs">vs</span> ${fx.inside}</span>
          ${result}${loadBtn}
        </div>`;
      }).join('');
    }

    // ─── Keyboard shortcuts ───────────────────────────────────────────────────

    document.addEventListener('keydown', e => {
      // Ignore when typing in an input field
      if (e.target.tagName === 'INPUT') return;
      switch (e.key.toLowerCase()) {
        case 'q': toggleTimer();   break;
        case 'o': outsideScores(); break;
        case 'p': insideScores();  break;
      }
    });

    // Enter key on fixture inputs
    document.getElementById('fx-outside-input').addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('fx-inside-input').focus();
    });
    document.getElementById('fx-inside-input').addEventListener('keydown', e => {
      if (e.key === 'Enter') addFixture();
    });

    // ─── Init ─────────────────────────────────────────────────────────────────

    updateButtonLabels();
    render();
    renderTimer();
    renderSeriesBar();
    refreshDatalist();
  </script>

</body>
</html>
